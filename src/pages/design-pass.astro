---
/*
 * Design Pass Preview Page
 *
 * Renders the four mockups (Hero-A, Problem-A, Hero-B, Problem-B)
 * so the two palette + typography directions can be compared side-by-side.
 *
 * Grouped by direction (A then B) so the visual system of each reads cleanly.
 *
 * Fonts loaded via Google Fonts <link> scoped to this page only.
 * Both token files are imported here — they coexist because each is scoped
 * under its own [data-direction="..."] selector and never hits :root.
 *
 * This page is temporary. Do not link it from the production nav.
 * Clean-up happens in Phase 6, after a direction is picked.
 */
import HeroA from '../components/sections/_design-pass/HeroA.astro';
import ProblemA from '../components/sections/_design-pass/ProblemA.astro';
import HeroB from '../components/sections/_design-pass/HeroB.astro';
import ProblemB from '../components/sections/_design-pass/ProblemB.astro';

// Direction A won. tokens.css now applies to :root globally.
// Direction B mockups will degrade visually on this page — fine,
// it's a temporary preview scheduled for Phase 6 cleanup.
import '../styles/tokens.css';
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Agence IA — Design Pass (A vs B)</title>

    <!-- Fonts: loaded scoped to this page only. No global font import yet. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,400..700,30;1,9..144,400..700,30&family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <style>
      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        font-family:
          'Inter',
          -apple-system,
          BlinkMacSystemFont,
          'Segoe UI',
          sans-serif;
        background: #0a0a0a;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* Page-level banner to mark which direction is which. */
      .dp-banner {
        padding: 2.5rem 1.5rem;
        background: #000;
        color: #fff;
        border-top: 1px solid #222;
        border-bottom: 1px solid #222;
      }
      .dp-banner__inner {
        max-width: 72rem;
        margin: 0 auto;
      }
      .dp-banner__label {
        font-size: 0.75rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #888;
        margin-bottom: 0.75rem;
        display: block;
      }
      .dp-banner__title {
        font-size: 2rem;
        font-weight: 600;
        margin: 0 0 0.75rem 0;
        letter-spacing: -0.02em;
      }
      .dp-banner__subtitle {
        font-size: 1rem;
        color: #bbb;
        margin: 0;
        line-height: 1.6;
        max-width: 52rem;
      }

      .dp-swatch-row {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.25rem;
        flex-wrap: wrap;
      }
      .dp-swatch {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        color: #bbb;
        font-family: 'Inter', sans-serif;
      }
      .dp-swatch__chip {
        width: 14px;
        height: 14px;
        border-radius: 2px;
        border: 1px solid #333;
      }

      .dp-page-header {
        padding: 3rem 1.5rem 2rem;
        background: #000;
        color: #fff;
        text-align: center;
        border-bottom: 1px solid #222;
      }
      .dp-page-header h1 {
        font-family: 'Inter', sans-serif;
        font-size: 1.5rem;
        font-weight: 600;
        margin: 0 0 0.5rem 0;
        letter-spacing: -0.01em;
      }
      .dp-page-header p {
        font-size: 0.875rem;
        color: #888;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <header class="dp-page-header">
      <h1>Agence IA — Design Pass</h1>
      <p>Two directions to evaluate. Pick A or B before Phase 3.</p>
    </header>

    <!-- ================================================================ -->
    <!-- DIRECTION A — Warm Contrast (Navy + Amber)                        -->
    <!-- ================================================================ -->
    <div class="dp-banner">
      <div class="dp-banner__inner">
        <span class="dp-banner__label">Direction A</span>
        <h2 class="dp-banner__title">Warm Contrast · Navy + Aged Brass</h2>
        <p class="dp-banner__subtitle">
          Deep navy ground, warm off-white typography, muted aged-brass amber accent.
          Display: Fraunces (editorial serif). Body: Inter. Reads like an
          architect's study or a serious financial advisory firm.
        </p>
        <div class="dp-swatch-row">
          <div class="dp-swatch">
            <span class="dp-swatch__chip" style="background:#0B1B2E"></span>
            #0B1B2E · bg
          </div>
          <div class="dp-swatch">
            <span class="dp-swatch__chip" style="background:#F5F1EA"></span>
            #F5F1EA · fg
          </div>
          <div class="dp-swatch">
            <span class="dp-swatch__chip" style="background:#C8863A"></span>
            #C8863A · accent
          </div>
          <div class="dp-swatch">
            <span class="dp-swatch__chip" style="background:#8A9BB0"></span>
            #8A9BB0 · muted
          </div>
        </div>
      </div>
    </div>

    <HeroA />
    <ProblemA />

    <!-- ================================================================ -->
    <!-- DIRECTION B — Cool Monochrome (Slate + Ice)                       -->
    <!-- ================================================================ -->
    <div class="dp-banner">
      <div class="dp-banner__inner">
        <span class="dp-banner__label">Direction B</span>
        <h2 class="dp-banner__title">Cool Monochrome · Slate + Ice Blue</h2>
        <p class="dp-banner__subtitle">
          Sophisticated slate-blue ground, cool off-white typography, restrained
          ice-blue accent within the same family. Display: Instrument Serif
          (modern editorial). Body: Inter. Reads like an engineering firm or
          quiet Swiss consultancy.
        </p>
        <div class="dp-swatch-row">
          <div class="dp-swatch">
            <span class="dp-swatch__chip" style="background:#0F1A2B"></span>
            #0F1A2B · bg
          </div>
          <div class="dp-swatch">
            <span class="dp-swatch__chip" style="background:#EBEEF3"></span>
            #EBEEF3 · fg
          </div>
          <div class="dp-swatch">
            <span class="dp-swatch__chip" style="background:#7FB3D5"></span>
            #7FB3D5 · accent
          </div>
          <div class="dp-swatch">
            <span class="dp-swatch__chip" style="background:#6B7D94"></span>
            #6B7D94 · muted
          </div>
        </div>
      </div>
    </div>

    <HeroB />
    <ProblemB />

    <footer class="dp-page-header">
      <h1>End of design pass</h1>
      <p>
        Pick A or B. The chosen tokens file will be renamed to
        <code>tokens.css</code> in Phase 3.
      </p>
    </footer>
  </body>
</html>
