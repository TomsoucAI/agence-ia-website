---
/*
 * Homepage — single-page marketing site (spec §1, §3).
 *
 * Full composition per spec §3 section order:
 *   Hero → Problem → Approach → Framework → BuiltFor → Services →
 *   Process → Outcomes → Formation → Team → Faq → FinalCta → Footer.
 *
 * Phase 5 adds the last five sections; Phase 6 will add the sticky top
 * nav and the legal subpages.
 *
 * <title> and <meta description> are in Quebec French, sourced from
 * the content layer where possible and site-level meta otherwise.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Problem from '../components/sections/Problem.astro';
import Approach from '../components/sections/Approach.astro';
import Framework from '../components/sections/Framework.astro';
import BuiltFor from '../components/sections/BuiltFor.astro';
import Services from '../components/sections/Services.astro';
import Process from '../components/sections/Process.astro';
import Outcomes from '../components/sections/Outcomes.astro';
import Formation from '../components/sections/Formation.astro';
import Team from '../components/sections/Team.astro';
import Faq from '../components/sections/Faq.astro';
import FinalCta from '../components/sections/FinalCta.astro';
import Footer from '../components/sections/Footer.astro';
import { siteContent } from '../content/site';

const pageTitle = `${siteContent.meta.brandName} — ${siteContent.hero.eyebrow}`;
const pageDescription = siteContent.hero.subhead;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main>
    <Hero />
    <Problem />
    <Approach />
    <Framework />
    <BuiltFor />
    <Services />
    <Process />
    <Outcomes />
    <Formation />
    <Team />
    <Faq />
    <FinalCta />
  </main>
  <Footer />
</BaseLayout>
