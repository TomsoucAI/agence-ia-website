---
/*
 * Homepage — single-page marketing site (spec §1, §3).
 *
 * Full composition per spec §3 section order:
 *   Hero → Problem → Approach → Framework → BuiltFor → Services →
 *   Process → Outcomes → Formation → Team → Faq → FinalCta → Reserver → Footer.
 *
 * Phase 6 adds:
 *   - StickyNav (lives in BaseLayout so every page gets it)
 *   - Reserver section at the bottom, id="reserver" — anchor target of every
 *     primary "Réserver un audit" CTA across the site
 *   - Meta + OG + Twitter card tags via BaseLayout's meta prop chain
 *   - Legal subpages (mentions-legales, politique-confidentialite) as siblings
 *
 * <title> and <meta description> come from siteContent.meta (Quebec French).
 * BaseLayout falls back to site-level meta when no per-page override is given,
 * so we could omit `title`/`description` here — passing them keeps intent
 * explicit and lets the homepage evolve without relying on the fallback.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Problem from '../components/sections/Problem.astro';
import Approach from '../components/sections/Approach.astro';
import Framework from '../components/sections/Framework.astro';
import BuiltFor from '../components/sections/BuiltFor.astro';
import Services from '../components/sections/Services.astro';
import Process from '../components/sections/Process.astro';
import Outcomes from '../components/sections/Outcomes.astro';
import Formation from '../components/sections/Formation.astro';
import Team from '../components/sections/Team.astro';
import Faq from '../components/sections/Faq.astro';
import FinalCta from '../components/sections/FinalCta.astro';
import Reserver from '../components/sections/Reserver.astro';
import Footer from '../components/sections/Footer.astro';
import { siteContent } from '../content/site';

const pageTitle = siteContent.meta.title;
const pageDescription = siteContent.meta.description;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main>
    <Hero />
    <Problem />
    <Approach />
    <Framework />
    <BuiltFor />
    <Services />
    <Process />
    <Outcomes />
    <Formation />
    <Team />
    <Faq />
    <FinalCta />
    <Reserver />
  </main>
  <Footer />
</BaseLayout>
