---
/*
 * Homepage — single-page marketing site (spec §1, §3).
 *
 * Phase 3 + Phase 4 composition: Hero → Problem → Approach → Framework →
 * BuiltFor → Services → Process → Outcomes.
 * The remaining five sections (Formation, Team, FAQ, FinalCta, Footer)
 * land in Phase 5.
 *
 * <title> and <meta description> are in Quebec French, sourced from
 * the content layer where possible and site-level meta otherwise.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Problem from '../components/sections/Problem.astro';
import Approach from '../components/sections/Approach.astro';
import Framework from '../components/sections/Framework.astro';
import BuiltFor from '../components/sections/BuiltFor.astro';
import Services from '../components/sections/Services.astro';
import Process from '../components/sections/Process.astro';
import Outcomes from '../components/sections/Outcomes.astro';
import { siteContent } from '../content/site';

const pageTitle = `${siteContent.meta.brandName} — ${siteContent.hero.eyebrow}`;
const pageDescription = siteContent.hero.subhead;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main>
    <Hero />
    <Problem />
    <Approach />
    <Framework />
    <BuiltFor />
    <Services />
    <Process />
    <Outcomes />
  </main>
</BaseLayout>
