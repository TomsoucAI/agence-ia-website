---
/*
 * Eyebrow — small pill-style section label above the headline.
 * Used at the top of every major section (Hero, Problem, Approach, Framework, …).
 * A single aged-brass dot + uppercased micro-label in a rounded border.
 *
 * Consumes no content directly — every string arrives via props so the
 * component stays pure markup.
 */

interface Props {
  readonly text: string;
  /** Optional extra class hooks for section-specific tweaks. */
  readonly class?: string;
}

const { text, class: extraClass } = Astro.props;
---

<span class:list={["ui-eyebrow", extraClass]}>
  <span class="ui-eyebrow__dot" aria-hidden="true"></span>
  <span class="ui-eyebrow__text">{text}</span>
</span>

<style>
  .ui-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: rgba(200, 134, 58, 0.05);
    font-family: var(--font-body);
  }

  .ui-eyebrow__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .ui-eyebrow__text {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-fg);
  }
</style>
