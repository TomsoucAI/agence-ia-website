---
/*
 * PriceCard — tiered pricing card with header, price band, duration, offers list,
 * and optional entry-point badge.
 *
 * Consumed by the Services section:
 *   - variant="tier"     : the three main tier cards. Full-size treatment with
 *                          offers list (via default slot), price + duration band,
 *                          and optional `entryPoint` badge (Tier 1 only).
 *   - variant="retainer" : the three retainer rows rendered below the tier grid.
 *                          Compact, horizontal layout with no offers list.
 *
 * The offers list is intentionally a slot so Services can pass either offers
 * (for tiers) or a single description line (for retainers).
 */

interface Props {
  readonly variant: 'tier' | 'retainer';
  /** Optional small badge/label above the card title (e.g. "Tier 1"). */
  readonly index?: string;
  readonly name: string;
  readonly priceLabel: string;
  /** Optional duration line below price (tiers only). */
  readonly durationLabel?: string;
  /** Optional description text (used by retainers). */
  readonly description?: string;
  /** Render the "Point d'entrée" badge on this card. Tier 1 only. */
  readonly entryPoint?: boolean;
  /** Label for the entry-point badge. */
  readonly entryPointLabel?: string;
  readonly class?: string;
}

const {
  variant,
  index,
  name,
  priceLabel,
  durationLabel,
  description,
  entryPoint = false,
  entryPointLabel,
  class: extraClass,
} = Astro.props;
---

<article
  class:list={[
    'ui-price-card',
    `ui-price-card--${variant}`,
    entryPoint && 'ui-price-card--entry',
    extraClass,
  ]}
>
  {entryPoint && entryPointLabel && (
    <span class="ui-price-card__entry-badge" aria-label={entryPointLabel}>
      <span class="ui-price-card__entry-dot" aria-hidden="true"></span>
      {entryPointLabel}
    </span>
  )}

  <header class="ui-price-card__header">
    {index && (
      <span class="ui-price-card__index" aria-hidden="true">{index}</span>
    )}
    <h3 class="ui-price-card__name">{name}</h3>
  </header>

  <div class="ui-price-card__price-band">
    <span class="ui-price-card__price">{priceLabel}</span>
    {durationLabel && (
      <span class="ui-price-card__duration">{durationLabel}</span>
    )}
  </div>

  {description && (
    <p class="ui-price-card__description">{description}</p>
  )}

  <div class="ui-price-card__body">
    <slot />
  </div>
</article>

<style>
  .ui-price-card {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: rgba(245, 241, 234, 0.02);
    color: var(--color-fg);
    font-family: var(--font-body);
    transition:
      border-color 200ms ease,
      background-color 200ms ease;
    display: flex;
    flex-direction: column;
  }

  .ui-price-card:hover {
    border-color: var(--color-muted);
  }

  /* ------------------------------------------------------------------
   * Tier variant — full-size card with offers list
   * ---------------------------------------------------------------- */
  .ui-price-card--tier {
    padding: var(--space-7) var(--space-6) var(--space-6);
    min-height: 100%;
  }

  /* Entry-point treatment — subtle amber emphasis that draws the eye without
   * making Tier 1 visually louder than Tier 2 or Tier 3. The cue is the badge
   * + a faint amber border tint, not a heavy background. */
  .ui-price-card--entry {
    border-color: rgba(200, 134, 58, 0.55);
    background:
      linear-gradient(
        180deg,
        rgba(200, 134, 58, 0.05) 0%,
        rgba(200, 134, 58, 0.01) 60%
      );
  }
  .ui-price-card--entry:hover {
    border-color: var(--color-accent);
  }

  .ui-price-card__entry-badge {
    position: absolute;
    top: calc(-1 * var(--space-3));
    left: var(--space-5);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    background: var(--color-accent);
    color: var(--color-bg);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 999px;
    box-shadow: 0 2px 0 0 rgba(0, 0, 0, 0.25);
  }
  .ui-price-card__entry-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-bg);
  }

  .ui-price-card__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .ui-price-card__index {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }

  .ui-price-card__name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-2xl);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--color-fg);
  }

  .ui-price-card__price-band {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-5);
  }

  .ui-price-card__price {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 500;
    color: var(--color-accent);
    line-height: 1.1;
    font-variant-numeric: tabular-nums;
  }

  .ui-price-card__duration {
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .ui-price-card__description {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-muted);
    margin: 0;
  }

  .ui-price-card__body {
    margin-top: auto;
  }

  /* ------------------------------------------------------------------
   * Retainer variant — compact horizontal row
   * ---------------------------------------------------------------- */
  .ui-price-card--retainer {
    padding: var(--space-5) var(--space-5);
    display: grid;
    grid-template-columns: minmax(8rem, 1fr) auto 2.2fr;
    align-items: center;
    gap: var(--space-5);
  }

  .ui-price-card--retainer .ui-price-card__header {
    margin-bottom: 0;
    gap: 0;
  }

  .ui-price-card--retainer .ui-price-card__name {
    font-size: var(--text-xl);
  }

  .ui-price-card--retainer .ui-price-card__price-band {
    padding: 0;
    border: none;
    margin: 0;
    flex-direction: row;
    align-items: baseline;
    gap: var(--space-3);
    white-space: nowrap;
  }

  .ui-price-card--retainer .ui-price-card__price {
    font-size: var(--text-xl);
  }

  .ui-price-card--retainer .ui-price-card__description {
    font-size: var(--text-sm);
  }

  .ui-price-card--retainer .ui-price-card__body {
    margin-top: 0;
  }

  @media (max-width: 768px) {
    .ui-price-card--retainer {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
    .ui-price-card--retainer .ui-price-card__price-band {
      justify-content: flex-start;
    }
  }
</style>
