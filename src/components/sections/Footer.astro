---
/*
 * Section: Footer (§4.13)
 *
 * Brand mark · anchor nav repeat · legal links · Discord (if resolved) ·
 * LinkedIn (only resolved URLs) · Quebec-French copyright line.
 *
 * TODO sentinel handling:
 *   - Discord URL is a Resolvable<string>. If still TODO, the link is OMITTED
 *     entirely (no dead anchor).
 *   - LinkedIn URLs come as a `linkedinUrls: NavLink[]` array — currently
 *     empty at Phase 5. We only render resolved entries, so an empty array
 *     cleanly produces no links.
 *   - Contact email is `string | null` — when null, the Contact legal link
 *     in site.ts still points to `#final-cta`; we honour that href.
 */

import { siteContent } from '../../content/site';
import { isTodo } from '../../content/types';

const { footer } = siteContent;

const discordResolved = !isTodo(footer.discordUrl);
const discordHref = discordResolved ? (footer.discordUrl as string) : null;

// Swap the "Contact" legal link to a mailto: when a contact email is present.
// The content layer's fallback (#final-cta) remains in place otherwise.
const legalLinks = footer.legal.map((link) => {
  if (link.label === 'Contact' && footer.contactEmail) {
    return { ...link, href: `mailto:${footer.contactEmail}` };
  }
  return link;
});

const currentYear = new Date().getFullYear();
const copyright = `© ${currentYear} ${footer.brandName}. Tous droits réservés.`;
---

<footer class="footer" aria-label="Pied de page">
  <div class="footer__inner">
    <div class="footer__top">
      <div class="footer__brand">
        <span class="footer__brand-mark">{footer.brandName}</span>
        <p class="footer__brand-tag">
          Agence IA québécoise. Déploiements locaux, en français.
        </p>
      </div>

      <nav class="footer__nav" aria-label="Navigation du pied de page">
        <span class="footer__nav-label">Sections</span>
        <ul class="footer__nav-list">
          {
            footer.anchorNav.map((link) => (
              <li>
                <a href={link.href} class="footer__nav-link">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="footer__links">
        <span class="footer__nav-label">Liens</span>
        <ul class="footer__nav-list">
          {
            legalLinks.map((link) => (
              <li>
                <a href={link.href} class="footer__nav-link">
                  {link.label}
                </a>
              </li>
            ))
          }
          {discordHref && (
            <li>
              <a
                href={discordHref}
                class="footer__nav-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                Discord
              </a>
            </li>
          )}
          {footer.linkedinUrls.map((link) => (
            <li>
              <a
                href={link.href}
                class="footer__nav-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">{copyright}</p>
      <p class="footer__location">Québec, Canada</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg);
    color: var(--color-fg);
    font-family: var(--font-body);
    padding: var(--space-11) var(--space-6) var(--space-9);
    border-top: 1px solid var(--color-border);
  }

  .footer__inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: var(--space-9);
    padding-bottom: var(--space-9);
    border-bottom: 1px solid var(--color-border);
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__brand-mark {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-2xl);
    letter-spacing: -0.01em;
    color: var(--color-fg);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }

  .footer__brand-tag {
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--color-muted);
    margin: 0;
    max-width: 24rem;
  }

  .footer__nav-label {
    display: block;
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
    font-weight: 500;
  }

  .footer__nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__nav-link {
    font-size: var(--text-sm);
    color: var(--color-fg);
    text-decoration: none;
    transition: color 180ms ease;
  }
  .footer__nav-link:hover {
    color: var(--color-accent);
  }
  .footer__nav-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-6);
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .footer__copyright,
  .footer__location {
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-muted);
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-7);
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .footer {
      padding: var(--space-10) var(--space-5) var(--space-8);
    }
    .footer__top {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
