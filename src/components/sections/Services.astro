---
/*
 * Section: Services (§4.6 — the three-tier catalog + retainers)
 *
 * The most important commercial section on the site. Three pricing tiers,
 * three retainers, and a "ce qu'on ne vend pas" trust block.
 *
 * Visual hierarchy:
 *   - Tier 1 is the entry point. It gets the "Point d'entrée" badge plus a
 *     subtle amber-tinted border — same size + rhythm as Tier 2 / Tier 3,
 *     never louder than them.
 *   - Tier 3 must NOT read as the headline. No "most popular" treatment.
 *   - Retainers live below the tier grid as a smaller, follow-on block.
 *     Gating copy ("offerts après 30 jours d'usage en production") sits
 *     above them so the rule is enforced visually.
 *   - "Ce qu'on ne vend pas" is a muted boundary block — intentional,
 *     not an afterthought.
 *
 * Custom wrapper (not Section.astro): the three-tier grid + retainer stack +
 * not-selling block each need their own rhythm that the generic Section
 * padding can't express cleanly. BuiltFor and Outcomes adopt Section.astro
 * for the base rhythm.
 */

import { siteContent } from '../../content/site';
import SectionHeader from '../ui/SectionHeader.astro';
import CtaPair from '../ui/CtaPair.astro';
import PriceCard from '../ui/PriceCard.astro';
import ScrollReveal from '../ui/ScrollReveal.astro';

const { services } = siteContent;
const { ctas, entryPointLabel } = services;

const tierIndexLabel = (i: number) => `Tier ${i + 1}`;
---

<section id="services" aria-label="Services" class="services">
  <div class="services__inner">
    <div class="services__top">
      <SectionHeader
        eyebrow={services.eyebrow}
        headline={services.headline}
        level="h2"
        scale="section"
        maxWidth={56}
        class="services__header"
      />
      <div class="services__top-cta">
        <CtaPair ctas={ctas} />
      </div>
    </div>

    <!-- Tier grid — three cards. Tier 1 carries the entry-point badge. -->
    <ul class="services__tier-grid" aria-label="Trois niveaux de services">
      {
        services.tiers.map((tier, i) => (
          <ScrollReveal
            as="li"
            delay={i * 0.08}
            className="services__tier-cell"
          >
            <PriceCard
              variant="tier"
              index={tierIndexLabel(i)}
              name={tier.name}
              priceLabel={tier.priceLabel}
              durationLabel={tier.durationLabel}
              entryPoint={i === 0}
              entryPointLabel={i === 0 ? entryPointLabel : undefined}
              class="services__tier-card"
            >
              <ul class="services__offers" aria-label={`Offres ${tier.name}`}>
                {tier.offers.map((offer) => (
                  <li class="services__offer">
                    <span class="services__offer-marker" aria-hidden="true">
                      +
                    </span>
                    <div class="services__offer-body">
                      <h4 class="services__offer-title">{offer.title}</h4>
                      <p class="services__offer-description">
                        {offer.description}
                      </p>
                    </div>
                  </li>
                ))}
              </ul>
            </PriceCard>
          </ScrollReveal>
        ))
      }
    </ul>

    <!-- Retainers — follow-on block, smaller visual treatment. -->
    <section class="services__retainers" aria-label="Retainers mensuels">
      <header class="services__retainers-header">
        <h3 class="services__retainers-title">Retainers mensuels</h3>
        <p class="services__retainers-intro">{services.retainerIntro}</p>
      </header>

      <ul class="services__retainer-list">
        {
          services.retainers.map((retainer, i) => (
            <ScrollReveal
              as="li"
              delay={i * 0.06}
              className="services__retainer-cell"
            >
              <PriceCard
                variant="retainer"
                name={retainer.name}
                priceLabel={retainer.priceLabel}
                description={retainer.description}
              />
            </ScrollReveal>
          ))
        }
      </ul>
    </section>

    <!-- "Ce qu'on ne vend pas" — trust block, muted, intentional. -->
    <aside class="services__boundaries" aria-label="Limites de notre offre">
      <header class="services__boundaries-header">
        <span class="services__boundaries-tag">Limites</span>
        <h3 class="services__boundaries-title">{services.notSellingTitle}</h3>
      </header>
      <ul class="services__boundaries-list">
        {
          services.notSelling.map((item) => (
            <li class="services__boundary">{item}</li>
          ))
        }
      </ul>
    </aside>
  </div>
</section>

<style>
  .services {
    background: var(--color-bg);
    color: var(--color-fg);
    font-family: var(--font-body);
    padding: var(--space-12) var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .services__inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  .services__top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-8);
    margin-bottom: var(--space-11);
    flex-wrap: wrap;
  }

  .services__top-cta {
    flex-shrink: 0;
  }

  /* ------------------------------------------------------------------
   * Tier grid — three columns at desktop, stacked on mobile.
   * Top padding on the grid reserves room for the Tier 1 entry badge
   * that sits above the card border (translated up).
   * ---------------------------------------------------------------- */
  .services__tier-grid {
    list-style: none;
    padding: var(--space-4) 0 0 0;
    margin: 0 0 var(--space-11) 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .services__tier-cell {
    display: block;
    height: 100%;
  }

  :global(.services__tier-card) {
    height: 100%;
  }

  /* Offers list — tokens-only treatment, no icons. */
  .services__offers {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .services__offer {
    display: grid;
    grid-template-columns: 1.25rem 1fr;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .services__offer-marker {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: 1;
    color: var(--color-accent);
    text-align: center;
    padding-top: 0.125rem;
  }

  .services__offer-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .services__offer-title {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-sm);
    line-height: 1.4;
    margin: 0;
    color: var(--color-fg);
  }

  .services__offer-description {
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--color-muted);
    margin: 0;
  }

  /* ------------------------------------------------------------------
   * Retainers — tighter, smaller than tiers.
   * ---------------------------------------------------------------- */
  .services__retainers {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-9);
    margin-bottom: var(--space-10);
  }

  .services__retainers-header {
    max-width: 42rem;
    margin-bottom: var(--space-6);
  }

  .services__retainers-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-2xl);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0 0 var(--space-2) 0;
    color: var(--color-fg);
  }

  .services__retainers-intro {
    font-size: var(--text-sm);
    letter-spacing: 0.02em;
    color: var(--color-accent);
    margin: 0;
    font-style: italic;
  }

  .services__retainer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .services__retainer-cell {
    display: block;
  }

  /* ------------------------------------------------------------------
   * Boundaries — "Ce qu'on ne vend pas"
   * Muted, lower-contrast, intentionally quiet so it reads as a
   * trust-building boundary statement and not a weakness.
   * ---------------------------------------------------------------- */
  .services__boundaries {
    border-top: 1px solid var(--color-border);
    padding: var(--space-7) var(--space-6);
    margin-top: var(--space-4);
    background: rgba(11, 27, 46, 0.4);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .services__boundaries-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .services__boundaries-tag {
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 500;
  }

  .services__boundaries-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-lg);
    letter-spacing: -0.005em;
    line-height: 1.3;
    margin: 0;
    color: var(--color-fg);
  }

  .services__boundaries-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .services__boundary {
    font-size: var(--text-sm);
    color: var(--color-muted);
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: rgba(245, 241, 234, 0.02);
  }

  /* ------------------------------------------------------------------
   * Responsive
   * ---------------------------------------------------------------- */
  @media (max-width: 1024px) {
    .services__tier-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }

  @media (max-width: 768px) {
    .services__top {
      align-items: flex-start;
    }
  }

  @media (max-width: 640px) {
    .services {
      padding: var(--space-10) var(--space-5);
    }
    .services__boundaries {
      padding: var(--space-6) var(--space-5);
    }
  }
</style>
