---
/*
 * Section: Outcomes (§4.8 — concrete results)
 *
 * Three to four outcome cards framed as quantified benchmarks, not
 * testimonials (no case studies at launch per spec §8). Each card pairs a
 * Fraunces headline with a short muted description.
 *
 * Adopts Section.astro for base padding/rhythm (second adoption) — the
 * grid fits inside the standard 72rem inner container cleanly.
 *
 * Staggered reveal via ScrollReveal island per the prompt.
 */

import { siteContent } from '../../content/site';
import Section from '../ui/Section.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import CtaPair from '../ui/CtaPair.astro';
import Card from '../ui/Card.astro';
import ScrollReveal from '../ui/ScrollReveal.astro';

const { outcomes } = siteContent;
const { ctas } = outcomes;
---

<Section id="outcomes" ariaLabel="Résultats concrets" class="outcomes">
  <div class="outcomes__top">
    <SectionHeader
      eyebrow={outcomes.eyebrow}
      headline={outcomes.headline}
      level="h2"
      scale="section"
      maxWidth={48}
      class="outcomes__header"
    />
    <div class="outcomes__top-cta">
      <CtaPair ctas={ctas} />
    </div>
  </div>

  <ul class="outcomes__grid" aria-label="Résultats concrets">
    {
      outcomes.items.map((item, i) => (
        <ScrollReveal
          as="li"
          delay={i * 0.08}
          className="outcomes__cell"
        >
          <Card padding="lg" class="outcomes__card">
            <span class="outcomes__index" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="outcomes__card-title">{item.title}</h3>
            <p class="outcomes__card-body">{item.description}</p>
          </Card>
        </ScrollReveal>
      ))
    }
  </ul>
</Section>

<style>
  .outcomes__top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-8);
    margin-bottom: var(--space-10);
    flex-wrap: wrap;
  }

  .outcomes__top-cta {
    flex-shrink: 0;
  }

  .outcomes__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
  }

  .outcomes__cell {
    display: block;
  }

  :global(.outcomes__card) {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .outcomes__index {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--color-accent);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
    font-variant-numeric: tabular-nums;
  }

  .outcomes__card-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-2xl);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-3) 0;
    color: var(--color-fg);
  }

  .outcomes__card-body {
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-muted);
    margin: 0;
  }

  @media (max-width: 768px) {
    .outcomes__grid {
      grid-template-columns: 1fr;
    }
    .outcomes__top {
      align-items: flex-start;
    }
  }
</style>
