---
/*
 * Problem · Direction B (Cool Monochrome)
 * Spec: §4.2 — the wedge
 * Stats are TODO (sentinel) — render clearly marked placeholders.
 * Palette: slate-blue + cool off-white + ice-blue accent
 */
import { siteContent } from '../../../content/site';
import { isTodo } from '../../../content/types';
const { problem } = siteContent;

const statPlaceholders = [
  'À compléter — stat #1',
  'À compléter — stat #2',
  'À compléter — stat #3',
];
const statsResolved = !isTodo(problem.stats);
---

<section
  data-direction="b"
  aria-label="Le problème · Direction B"
  class="dp-problem-b"
>
  <div class="dp-problem-b__inner">
    <!-- Eyebrow + headline -->
    <div class="dp-problem-b__header">
      <div class="dp-problem-b__eyebrow-row">
        <span class="dp-problem-b__eyebrow-bar" aria-hidden="true"></span>
        <span class="dp-problem-b__eyebrow">{problem.eyebrow}</span>
      </div>
      <h2 class="dp-problem-b__headline">{problem.headline}</h2>
    </div>

    <!-- Stat block strip placeholder -->
    <div class="dp-problem-b__stat-strip" role="region" aria-label="Statistiques">
      <div class="dp-problem-b__stat-strip-track">
        {
          !statsResolved &&
            statPlaceholders.map((label) => (
              <div class="dp-problem-b__stat-pill">
                <span class="dp-problem-b__stat-value">—</span>
                <span class="dp-problem-b__stat-divider" aria-hidden="true" />
                <span class="dp-problem-b__stat-label">{label}</span>
              </div>
            ))
        }
      </div>
    </div>

    <!-- Problem cards grid -->
    <div class="dp-problem-b__grid">
      {
        problem.cards.map((card, i) => (
          <article class="dp-problem-b__card">
            <div class="dp-problem-b__card-index">
              {String(i + 1).padStart(2, '0')}
              <span class="dp-problem-b__card-index-label">/ 04</span>
            </div>
            <h3 class="dp-problem-b__card-title">{card.title}</h3>
            <p class="dp-problem-b__card-body">{card.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .dp-problem-b {
    background: var(--color-bg);
    color: var(--color-fg);
    font-family: var(--font-body);
    padding: var(--space-12) var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .dp-problem-b__inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  .dp-problem-b__header {
    max-width: 48rem;
    margin-bottom: var(--space-10);
  }

  .dp-problem-b__eyebrow-row {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .dp-problem-b__eyebrow-bar {
    width: 24px;
    height: 1px;
    background: var(--color-accent);
  }

  .dp-problem-b__eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .dp-problem-b__headline {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.875rem, 3.8vw + 0.5rem, var(--text-5xl));
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin: 0;
  }

  /* Stat strip — understated, engineering-grade */
  .dp-problem-b__stat-strip {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-5) 0;
    margin-bottom: var(--space-10);
    overflow: hidden;
  }

  .dp-problem-b__stat-strip-track {
    display: flex;
    gap: var(--space-10);
    align-items: center;
    flex-wrap: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .dp-problem-b__stat-strip-track::-webkit-scrollbar {
    display: none;
  }

  .dp-problem-b__stat-pill {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-shrink: 0;
    padding: var(--space-3) 0;
  }

  .dp-problem-b__stat-value {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 400;
    color: var(--color-accent);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .dp-problem-b__stat-divider {
    width: 1px;
    height: 36px;
    background: var(--color-border);
  }

  .dp-problem-b__stat-label {
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-style: italic;
    max-width: 14rem;
  }

  /* Problem cards */
  .dp-problem-b__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-left: 1px solid var(--color-border);
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .dp-problem-b__grid {
      grid-template-columns: 1fr;
    }
  }

  .dp-problem-b__card {
    padding: var(--space-7);
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    transition: background-color 180ms ease;
  }
  .dp-problem-b__card:hover {
    background: rgba(127, 179, 213, 0.04);
  }

  .dp-problem-b__card-index {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-accent);
    letter-spacing: 0.14em;
    margin-bottom: var(--space-5);
    font-variant-numeric: tabular-nums;
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
  }

  .dp-problem-b__card-index-label {
    color: var(--color-muted);
  }

  .dp-problem-b__card-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-2xl);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-3) 0;
  }

  .dp-problem-b__card-body {
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-muted);
    margin: 0;
  }
</style>
