---
/*
 * Problem · Direction A (Warm Contrast)
 * Spec: §4.2 — the wedge
 * Stats are TODO (sentinel) — render clearly marked placeholders.
 * Palette: deep navy + warm off-white + muted amber
 */
import { siteContent } from '../../../content/site';
import { isTodo } from '../../../content/types';
const { problem } = siteContent;

// Stats placeholder slots — do NOT invent data.
const statPlaceholders = [
  'À compléter — stat #1',
  'À compléter — stat #2',
  'À compléter — stat #3',
];
const statsResolved = !isTodo(problem.stats);
---

<section
  data-direction="a"
  aria-label="Le problème · Direction A"
  class="dp-problem"
>
  <div class="dp-problem__inner">
    <!-- Eyebrow + headline -->
    <div class="dp-problem__header">
      <div class="dp-problem__eyebrow-row">
        <span class="dp-problem__eyebrow-dot" aria-hidden="true"></span>
        <span class="dp-problem__eyebrow">{problem.eyebrow}</span>
      </div>
      <h2 class="dp-problem__headline">{problem.headline}</h2>
    </div>

    <!-- Stat block marquee placeholder -->
    <div class="dp-problem__stat-strip" role="region" aria-label="Statistiques">
      <div class="dp-problem__stat-strip-track">
        {
          statsResolved
            ? null /* real stats would render here once Tom supplies them */
            : statPlaceholders.map((label) => (
                <div class="dp-problem__stat-pill">
                  <span class="dp-problem__stat-value">—</span>
                  <span class="dp-problem__stat-label">{label}</span>
                </div>
              ))
        }
        {
          !statsResolved &&
            statPlaceholders.map((label) => (
              <div class="dp-problem__stat-pill" aria-hidden="true">
                <span class="dp-problem__stat-value">—</span>
                <span class="dp-problem__stat-label">{label}</span>
              </div>
            ))
        }
      </div>
    </div>

    <!-- Problem cards grid -->
    <div class="dp-problem__grid">
      {
        problem.cards.map((card, i) => (
          <article class="dp-problem__card">
            <div class="dp-problem__card-index">
              {String(i + 1).padStart(2, '0')}
            </div>
            <h3 class="dp-problem__card-title">{card.title}</h3>
            <p class="dp-problem__card-body">{card.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .dp-problem {
    background: var(--color-bg);
    color: var(--color-fg);
    font-family: var(--font-body);
    padding: var(--space-12) var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .dp-problem__inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  .dp-problem__header {
    max-width: 48rem;
    margin-bottom: var(--space-10);
  }

  .dp-problem__eyebrow-row {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: rgba(200, 134, 58, 0.05);
  }

  .dp-problem__eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .dp-problem__eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .dp-problem__headline {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.875rem, 3.6vw + 0.5rem, var(--text-5xl));
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
  }

  /* Stat strip — horizontal marquee-style placeholder */
  .dp-problem__stat-strip {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-5) 0;
    margin-bottom: var(--space-10);
    overflow: hidden;
  }

  .dp-problem__stat-strip-track {
    display: flex;
    gap: var(--space-8);
    align-items: center;
    flex-wrap: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .dp-problem__stat-strip-track::-webkit-scrollbar {
    display: none;
  }

  .dp-problem__stat-pill {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-shrink: 0;
    padding: var(--space-3) var(--space-5);
    border: 1px dashed var(--color-accent);
    border-radius: var(--radius-md);
    background: rgba(200, 134, 58, 0.04);
  }

  .dp-problem__stat-value {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 500;
    color: var(--color-accent);
    line-height: 1;
  }

  .dp-problem__stat-label {
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-style: italic;
  }

  /* Problem cards */
  .dp-problem__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
  }

  @media (max-width: 768px) {
    .dp-problem__grid {
      grid-template-columns: 1fr;
    }
  }

  .dp-problem__card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    background: rgba(245, 241, 234, 0.02);
    transition: border-color 180ms ease, background-color 180ms ease;
  }
  .dp-problem__card:hover {
    border-color: var(--color-accent);
    background: rgba(200, 134, 58, 0.04);
  }

  .dp-problem__card-index {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--color-accent);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
    font-variant-numeric: tabular-nums;
  }

  .dp-problem__card-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-2xl);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-3) 0;
  }

  .dp-problem__card-body {
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-muted);
    margin: 0;
  }
</style>
