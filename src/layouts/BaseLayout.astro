---
/*
 * BaseLayout — wraps every production page.
 *
 * Responsibilities:
 *   - Import globals.css (which @imports tokens.css) so design tokens
 *     cascade to every page that uses this layout
 *   - Load Fraunces (display) + Inter (body) from Google Fonts
 *   - Set lang="fr-CA" (site is French-first, Quebec variant)
 *   - Render a full <head>: <title>, description, canonical, OG, Twitter card
 *   - Inject the sticky anchor nav above <slot />
 *   - Conditionally inject the Plausible analytics script (guarded by TODO)
 *
 * Pages compose their section components inside the <slot />.
 */

import '../styles/globals.css';
import StickyNav from '../components/ui/StickyNav.astro';
import { siteContent } from '../content/site';
import { isTodo } from '../content/types';

interface Props {
  /** Page-specific <title>. Falls back to the site-level meta.title. */
  title?: string;
  /** Page-specific meta description. Falls back to meta.description. */
  description?: string;
  /** Path segment appended to site URL for canonical — e.g. "/mentions-legales". */
  pathname?: string;
}

const { title, description, pathname } = Astro.props;
const { meta } = siteContent;

const resolvedTitle = title ?? meta.title;
const resolvedDescription = description ?? meta.description;
const resolvedPath = pathname ?? Astro.url.pathname;

// Canonical URL. Astro exposes the configured `site` via import.meta.env.SITE
// and the project base path via import.meta.env.BASE_URL (e.g. "/Website/").
// When `site` is not set (domain still TODO), we fall back to the pathname
// alone — relative canonical still beats no canonical for crawlers.
const siteUrl = import.meta.env.SITE;
const baseUrl = import.meta.env.BASE_URL; // always ends with a trailing slash
const canonical = siteUrl
  ? new URL(resolvedPath, siteUrl).toString()
  : resolvedPath;
// OG image is a relative path in site.ts (e.g. "/og-image.png"). We join it
// with the base so the URL resolves under project-pages subpath deployments.
// Normalise: strip any trailing slash from base, ensure exactly one slash
// between the two halves, regardless of how either is authored.
const baseTrimmed = baseUrl.replace(/\/+$/, '');
const ogImageRel = meta.ogImage.replace(/^\/+/, '');
const ogImageAbs = `${baseTrimmed}/${ogImageRel}`;
const ogImageUrl = siteUrl
  ? new URL(ogImageAbs, siteUrl).toString()
  : ogImageAbs;

const plausibleResolved = !isTodo(meta.plausibleDomain);
const plausibleDomain = plausibleResolved
  ? (meta.plausibleDomain as string)
  : null;
---

<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <link rel="icon" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.ico`} />

    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonical} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_CA" />
    <meta property="og:site_name" content={meta.brandName} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,400..700,30;1,9..144,400..700,30&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {plausibleDomain && (
      <script
        defer
        data-domain={plausibleDomain}
        src="https://plausible.io/js/script.js"
      />
    )}
  </head>
  <body>
    <StickyNav />
    <div id="contenu-principal">
      <slot />
    </div>
  </body>
</html>
